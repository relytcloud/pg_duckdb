{
  "description": "Run DuckLake tests using MinIO.",
  "on_init": "CREATE SECRET (TYPE S3, KEY_ID 'admin', SECRET 'password', ENDPOINT '127.0.0.1:9000', URL_STYLE 'path', USE_SSL 0);",
  "test_env": [{
      "env_name":  "DATA_PATH",
      "env_value": "s3://mybucket"
   }],
  "skip_error_messages": ["this_is_not_allowed_to_be_empty"],
  "statically_loaded_extensions": [
    "core_functions",
    "parquet",
    "icu",
    "httpfs",
    "json"
  ],   "skip_tests": [
   {
      "reason": "Extension Loading tests, not relevant to remote files.",
      "paths": [
        "test/sql/general/missing_parquet.test",
        "test/sql/autoloading/autoload_data_path.test"
      ]
    },
  {
      "reason": "Test with a hardcoded file path.",
      "paths": [
        "test/sql/add_files/add_old_list.test",
        "test/sql/migration/migration.test",
        "test/sql/migration/per_table_schema.test",
        "test/sql/migration/v01_partitioned.test",
        "test/sql/delete/delete_ignore_extra_columns.test",
        "test/sql/add_files/add_file_with_three_level_list.test",
        "test/sql/migration/test_compaction.test",
        "test/sql/remove_orphans/metadata_in_data_path.test"
      ]
    }
  ]
}
