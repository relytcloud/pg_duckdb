-- Test setting GUCs
SET ducklake.default_table_path = '/tmp/test_path';
SHOW ducklake.default_table_path;
 ducklake.default_table_path 
-----------------------------
 /tmp/test_path
(1 row)

RESET ducklake.default_table_path;
SHOW ducklake.default_table_path;
 ducklake.default_table_path 
-----------------------------
 
(1 row)

