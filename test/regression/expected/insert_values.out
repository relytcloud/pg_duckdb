CREATE TABLE iv_bool (id int, flag boolean) USING ducklake;
SELECT count(*) FROM ducklake.ensure_inlined_data_table('iv_bool'::regclass);
 count 
-------
     1
(1 row)

INSERT INTO iv_bool VALUES (1, true), (2, false), (3, NULL);
